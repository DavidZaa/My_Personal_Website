# Supabase — create a project at https://supabase.com, then run
# supabase/migrations/0001_init.sql in the SQL editor (or `supabase db push`).
# Without these set, the site runs in demo mode with sample data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# The Google account allowed into /dashboard.
OWNER_EMAIL=

# GitHub personal access token (classic, read-only scopes) for live GitHub
# stats. Optional — falls back to unauthenticated public data without it.
GITHUB_TOKEN=

# Canonical site URL, used for OAuth redirects and metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
